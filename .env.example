# Local infrastructure
POSTGRES_DB=pc_agent
POSTGRES_USER=pc_agent
POSTGRES_PASSWORD=pc_agent
DATABASE_URL=postgresql+asyncpg://pc_agent:pc_agent@localhost:5432/pc_agent
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001

# LLM provider: qwen or deepseek
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_BASE_URL=

# App
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_USER_ID=1
VITE_API_BASE_URL=http://localhost:8000
