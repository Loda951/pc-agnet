# Local infrastructure
POSTGRES_DB=pc_agent
POSTGRES_USER=pc_agent
POSTGRES_PASSWORD=pc_agent
DATABASE_URL=postgresql+asyncpg://pc_agent:pc_agent@localhost:5432/pc_agent
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001
KNOWLEDGE_COLLECTION=pc_agent_knowledge
KNOWLEDGE_SCORE_THRESHOLD=0.16

# LLM provider: deepseek or qwen
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=

# App
APP_ENV=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_USER_ID=1
VITE_API_BASE_URL=http://localhost:8000
